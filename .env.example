# AdsPower Global Local API Configuration
# Port: Open AdsPower Global -> Settings -> Local API to find port
ADSPOWER_API_URL=http://local.adspower.net:64741
ADSPOWER_PROFILE_ID=your_profile_id_here
# API Key: Open AdsPower Global -> Settings -> Local API -> copy API Key
ADSPOWER_API_KEY=your_adspower_api_key_here

# OpenClaw / OpenAI API Key (only needed for AI mode, proxy mode doesn't need this)
OPENCLAW_API_KEY=your_api_key
